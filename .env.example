# =============================================================================
# VPN Core Service - Environment Configuration Example
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# Application
NODE_ENV=production
PORT=8080
API_GLOBAL_PREFIX=api

# Xray configuration
# Path to Xray config file (inside container)
# Must match the volume mount in docker-compose.yml
XRAY_CONFIG_PATH=/etc/xray/config.json
# Path to REALITY keys file (inside container)
XRAY_KEYS_PATH=/opt/xray/.keys

# Backend connection (for heartbeat and API calls)
BACKEND_URL=https://your-backend-domain.com
NODE_API_KEY=your-secure-node-api-key-here
NODE_ID=vps-your-node-id

# Heartbeat
HEARTBEAT_INTERVAL_MS=30000

# Audit
AUDIT_ENABLED=true

# Domain (for SSL certificates)
DOMAIN=your-domain.com
